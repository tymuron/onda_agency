# Resend API Key (Required for contact form emails)
RESEND_API_KEY=re_your_resend_key_here

# Your Email (Where to receive contact form notifications)
NOTIFICATION_EMAIL=your.email@example.com

# Analytics database. Use a free Neon pooled connection string in production.
# Leave unset locally to use a SQLite file (backend/analytics.db).
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname

# Password for the /admin analytics dashboard (HTTP Basic, username: admin)
ADMIN_PASSWORD=change-me

# Canonical site origin (used for SEO tags, sitemap, llms.txt)
SITE_URL=https://ondaweb.es
